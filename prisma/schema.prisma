generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id            String         @id @default(uuid())
  email         String         @unique
  full_name     String?
  role          String         @default("staff")
  avatar_url    String?
  created_at    DateTime       @default(now())
  notifications Notification[]
}

model Room {
  id           Int           @id @default(autoincrement())
  number       String        @unique
  type         String
  price        Float
  status       String        @default("Vacant")
  occupancy    String        @default("Clean")
  housekeeper  String?
  image_url    String?
  description  String?
  capacity     Int?          @default(2)
  gallery      Json?         @default("[]")
  features     Json?         @default("[]")
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  reservations Reservation[]
  amenities    Amenity[]
  reviews      Review[]
  tasks        Task[]
}

model Amenity {
  id    String @id @default(uuid())
  name  String @unique
  icon  String?
  rooms Room[]
}

model Guest {
  id           String        @id @default(uuid())
  email        String        @unique
  full_name    String
  phone        String?
  avatar_url   String?
  nationality  String?
  id_number    String?
  dob          DateTime?
  address      String?
  notes        String?
  created_at   DateTime      @default(now())
  reservations Reservation[]
  reviews      Review[]
}

model Reservation {
  id           String   @id @default(uuid())
  guest_id     String?
  guest_name   String
  guests_count Int      @default(1)
  nights       Int
  room_id      Int?
  room_type    String
  start_date   DateTime
  end_date     DateTime
  status       String   @default("Pending Approval")
  source       String   @default("Direct Site")
  total_price  Float?
  created_at   DateTime @default(now())
  room         Room?    @relation(fields: [room_id], references: [id])
  guest        Guest?   @relation(fields: [guest_id], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int      @default(5)
  comment    String?
  guest_id   String
  room_id    Int?
  created_at DateTime @default(now())
  guest      Guest    @relation(fields: [guest_id], references: [id])
  room       Room?    @relation(fields: [room_id], references: [id])
}

model Settings {
  id                    String   @id @default("global")
  hotel_name            String   @default("Golden Hills Hotel Setif")
  address               String   @default("Blvd des Orangers, Setif, Algeria")
  contact_email         String   @default("contact@goldenhills.dz")
  contact_phone         String   @default("+213 36 00 00 00")
  language              String   @default("English")
  timezone              String   @default("(GMT+01:00) Algiers, Casablanca, Tunis")
  currency              String   @default("DZD")
  logo_url              String?
  brand_color_primary   String   @default("#D4AF37")
  brand_color_secondary String   @default("#002349")
  font_family           String   @default("Inter")
  hero_image_url        String   @default("https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&q=80&w=2070")
  password_min_length   Int      @default(8)
  session_timeout       Int      @default(30)
  two_factor_enabled               Boolean  @default(false)
  data_retention_days              Int      @default(365)
  email_notifications_reservations Boolean  @default(true)
  email_notifications_stock        Boolean  @default(true)
  email_notifications_staff        Boolean  @default(false)
  updated_at                       DateTime @default(now()) @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  profile    Profile  @relation(fields: [user_id], references: [id])
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  role        String
  department  String
  status      String   @default("Off Shift")
  phone       String?
  email       String?
  avatar_url  String?
  dob         DateTime?
  address     String?
  id_number   String?
  joined_date DateTime? @default(now())
  salary      Float?
  created_at  DateTime @default(now())
  permissions Json?
  tasks       Task[]
}

model Task {
  id         String   @id @default(uuid())
  title       String
  description String?
  area        String?
  time        String?
  priority    String   @default("Normal")
  status      String   @default("Pending")
  type        String?
  completed   Boolean  @default(false)
  staff_id    String?
  room_id     Int?
  created_at  DateTime @default(now())
  staff       Staff?   @relation(fields: [staff_id], references: [id])
  room        Room?    @relation(fields: [room_id], references: [id])
}

model KitchenOrder {
  id         String   @id @default(uuid())
  table_id   String
  items      Json
  status     String   @default("Pending")
  time       DateTime @default(now())
  priority   String   @default("Normal")
  created_at DateTime @default(now())
}

model StockItem {
  id         String   @id @default(uuid())
  name       String
  level      String
  status     String   @default("Regular")
  category   String   @default("General")
  created_at DateTime @default(now())
}

model SecurityLog {
  id         String   @id @default(uuid())
  event      String
  status     String   @default("Info")
  time       DateTime @default(now())
  location   String?
  created_at DateTime @default(now())
}

model FinanceTransaction {
  id       String   @id @default(uuid())
  label    String
  value    Float
  type     String
  category String
  is_up    Boolean  @default(true)
  trend    String?
  date     DateTime @default(now())
}

model Service {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  image_url   String?
  hours       String?
  location    String?
  specialty   String?
  price       String?
  created_at  DateTime @default(now())
}

model BankAccount {
  id             String @id @default(uuid())
  account_number String
  bank_name      String
  balance        Float  @default(0)
}

model PaymentRequest {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("Pending")
  created_at DateTime @default(now())
}

model SecuritySystemStatus {
  id                String   @id @default("current")
  lockdown_active   Boolean  @default(false)
  biometric_locks   String   @default("Active")
  infrared_scanners String   @default("Active")
  radio_silent      String   @default("Inactive")
  last_audit        DateTime @default(now())
  system_health     Int      @default(100)
}
