generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id         String   @id @default(uuid())
  email      String   @unique
  full_name  String?
  role       String   @default("staff")
  avatar_url String?
  created_at DateTime @default(now())
}

model Room {
  id           Int           @id @default(autoincrement())
  number       String        @unique
  type         String
  price        Float
  status       String        @default("Vacant")
  occupancy    String        @default("Clean")
  housekeeper  String?
  image_url    String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  reservations Reservation[]
}

model Reservation {
  id           String   @id @default(uuid())
  guest_name   String
  guests_count Int      @default(1)
  nights       Int
  room_id      Int?
  room_type    String
  start_date   DateTime
  end_date     DateTime
  status       String   @default("Pending Approval")
  source       String   @default("Direct Site")
  created_at   DateTime @default(now())
  room         Room?    @relation(fields: [room_id], references: [id])
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  role        String
  department  String
  status      String   @default("Off Shift")
  phone       String?
  email       String?
  avatar_url  String?
  created_at  DateTime @default(now())
  permissions Json?
  tasks       Task[]
}

model Task {
  id         String   @id @default(uuid())
  title      String
  area       String
  time       String?
  priority   String   @default("Normal")
  type       String
  completed  Boolean  @default(false)
  staff_id   String?
  created_at DateTime @default(now())
  staff      Staff?   @relation(fields: [staff_id], references: [id])
}

model KitchenOrder {
  id         String   @id @default(uuid())
  table_id   String
  items      Json
  status     String   @default("Pending")
  time       DateTime @default(now())
  priority   String   @default("Normal")
  created_at DateTime @default(now())
}

model StockItem {
  id         String   @id @default(uuid())
  name       String
  level      String
  status     String   @default("Regular")
  category   String   @default("General")
  created_at DateTime @default(now())
}

model SecurityLog {
  id         String   @id @default(uuid())
  event      String
  status     String   @default("Info")
  time       DateTime @default(now())
  location   String?
  created_at DateTime @default(now())
}

model FinanceTransaction {
  id       String   @id @default(uuid())
  label    String
  value    Float
  type     String
  category String
  is_up    Boolean  @default(true)
  trend    String?
  date     DateTime @default(now())
}
